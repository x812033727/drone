{
  "components": {
    "schemas": {
      "CommandKind": {
        "enum": [
          "pause",
          "resume",
          "abort"
        ],
        "title": "CommandKind",
        "type": "string"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "Mission": {
        "properties": {
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "current_item": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Current Item"
          },
          "dispatched_at": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Dispatched At"
          },
          "drone_id": {
            "title": "Drone Id",
            "type": "string"
          },
          "finished_at": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Finished At"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          },
          "mission_id": {
            "title": "Mission Id",
            "type": "string"
          },
          "route_id": {
            "anyOf": [
              {
                "format": "uuid",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Route Id"
          },
          "rtl_after_last": {
            "title": "Rtl After Last",
            "type": "boolean"
          },
          "status": {
            "$ref": "#/components/schemas/MissionStatus"
          },
          "total_items": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Total Items"
          },
          "waypoints": {
            "items": {
              "$ref": "#/components/schemas/Waypoint"
            },
            "title": "Waypoints",
            "type": "array"
          }
        },
        "required": [
          "id",
          "mission_id",
          "drone_id",
          "status",
          "waypoints",
          "rtl_after_last",
          "created_at"
        ],
        "title": "Mission",
        "type": "object"
      },
      "MissionCommandRequest": {
        "properties": {
          "command": {
            "$ref": "#/components/schemas/CommandKind"
          }
        },
        "required": [
          "command"
        ],
        "title": "MissionCommandRequest",
        "type": "object"
      },
      "MissionCreate": {
        "description": "由 route + 目標機建立任務(凍結 route 當下的航點)。",
        "properties": {
          "drone_id": {
            "title": "Drone Id",
            "type": "string"
          },
          "route_id": {
            "format": "uuid",
            "title": "Route Id",
            "type": "string"
          }
        },
        "required": [
          "route_id",
          "drone_id"
        ],
        "title": "MissionCreate",
        "type": "object"
      },
      "MissionStatus": {
        "enum": [
          "created",
          "dispatched",
          "received",
          "uploaded",
          "in_progress",
          "paused",
          "completed",
          "failed"
        ],
        "title": "MissionStatus",
        "type": "string"
      },
      "Route": {
        "properties": {
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          },
          "name": {
            "title": "Name",
            "type": "string"
          },
          "org_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Org Id"
          },
          "rtl_after_last": {
            "title": "Rtl After Last",
            "type": "boolean"
          },
          "waypoints": {
            "items": {
              "$ref": "#/components/schemas/Waypoint"
            },
            "title": "Waypoints",
            "type": "array"
          }
        },
        "required": [
          "id",
          "name",
          "waypoints",
          "rtl_after_last",
          "created_at"
        ],
        "title": "Route",
        "type": "object"
      },
      "RouteCreate": {
        "properties": {
          "name": {
            "title": "Name",
            "type": "string"
          },
          "org_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Org Id"
          },
          "rtl_after_last": {
            "default": true,
            "title": "Rtl After Last",
            "type": "boolean"
          },
          "waypoints": {
            "items": {
              "$ref": "#/components/schemas/Waypoint"
            },
            "minItems": 1,
            "title": "Waypoints",
            "type": "array"
          }
        },
        "required": [
          "name",
          "waypoints"
        ],
        "title": "RouteCreate",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      },
      "Waypoint": {
        "description": "對 interfaces/proto/drone/v1/mission.proto 的 Waypoint。",
        "properties": {
          "hold_s": {
            "default": 0.0,
            "title": "Hold S",
            "type": "number"
          },
          "lat_deg": {
            "title": "Lat Deg",
            "type": "number"
          },
          "lon_deg": {
            "title": "Lon Deg",
            "type": "number"
          },
          "rel_alt_m": {
            "default": 0.0,
            "title": "Rel Alt M",
            "type": "number"
          },
          "speed_ms": {
            "default": 0.0,
            "title": "Speed Ms",
            "type": "number"
          }
        },
        "required": [
          "lat_deg",
          "lon_deg"
        ],
        "title": "Waypoint",
        "type": "object"
      }
    },
    "securitySchemes": {
      "HTTPBearer": {
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "title": "mission-svc",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/v1/missions": {
      "get": {
        "operationId": "list_missions_api_v1_missions_get",
        "parameters": [
          {
            "in": "query",
            "name": "drone_id",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Drone Id"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/Mission"
                  },
                  "title": "Response List Missions Api V1 Missions Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "summary": "List Missions"
      },
      "post": {
        "operationId": "create_mission_api_v1_missions_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MissionCreate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Mission"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "summary": "Create Mission"
      }
    },
