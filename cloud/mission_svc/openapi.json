    "/api/v1/missions/{mission_pk}/dispatch": {
      "post": {
        "operationId": "dispatch_mission_api_v1_missions__mission_pk__dispatch_post",
        "parameters": [
          {
            "in": "path",
            "name": "mission_pk",
            "required": true,
            "schema": {
              "format": "uuid",
              "title": "Mission Pk",
              "type": "string"
