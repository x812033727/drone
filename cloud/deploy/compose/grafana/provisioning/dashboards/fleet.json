{
  "uid": "drone-fleet",
  "title": "Fleet 機隊總覽",
  "tags": [
    "drone",
    "phase0"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "geomap",
      "title": "即時位置與軌跡",
      "gridPos": {
        "h": 12,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "drone-tsdb"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT time, drone_id, lat_deg, lon_deg FROM telemetry WHERE $__timeFilter(time) ORDER BY time"
        }
      ],
      "options": {
        "view": {
          "id": "fit"
        },
        "basemap": {
          "type": "default"
        },
        "layers": [
          {
            "type": "markers",
            "name": "軌跡點",
            "location": {
              "mode": "coords",
              "latitude": "lat_deg",
              "longitude": "lon_deg"
            },
            "config": {
              "style": {
                "size": {
                  "fixed": 4
                },
                "color": {
                  "field": "drone_id",
                  "fixed": "dark-blue"
                }
              }
            }
          }
        ]
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "電池電量(%)",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "drone-tsdb"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT time, drone_id, battery_pct FROM telemetry WHERE $__timeFilter(time) ORDER BY time"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "相對高度(m)",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "datasource": {
        "type": "postgres",
        "uid": "drone-tsdb"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "lengthm"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT time, drone_id, rel_alt_m FROM telemetry WHERE $__timeFilter(time) ORDER BY time"
        }
      ]
    },
    {
      "id": 4,
      "type": "table",
      "title": "各機最新狀態",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "postgres",
        "uid": "drone-tsdb"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT DISTINCT ON (drone_id) drone_id, time AS 最後回報, EXTRACT(EPOCH FROM (now() - time))::int AS 距今秒, flight_mode, armed, battery_v, battery_pct, health_all_ok FROM telemetry ORDER BY drone_id, time DESC"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "距今秒"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 10
                    },
                    {
                      "color": "red",
                      "value": 30
                    }
                  ]
                }
              },
              {
                "id": "unit",
                "value": "s"
              }
            ]
          }
        ]
      }
    },
    {
      "id": 5,
      "type": "table",
      "title": "任務進度事件",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "datasource": {
        "type": "postgres",
        "uid": "drone-tsdb"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT time, drone_id, mission_id, current_item, total_items, state FROM mission_progress WHERE $__timeFilter(time) ORDER BY time DESC LIMIT 100"
        }
      ]
    }
  ]
}