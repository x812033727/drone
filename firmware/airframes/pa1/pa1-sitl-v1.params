1	1	BAT_LOW_THR	0.20	9
1	1	COM_LOW_BAT_ACT	3	6
1	1	COM_OBL_RC_ACT	0	6
1	1	COM_RC_LOSS_T	0.5	9
1	1	GF_ACTION	3	6
