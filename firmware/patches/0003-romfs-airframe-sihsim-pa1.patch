diff --git a/ROMFS/px4fmu_common/init.d-posix/airframes/10990_sihsim_pa1 b/ROMFS/px4fmu_common/init.d-posix/airframes/10990_sihsim_pa1
new file mode 100644
index 0000000..0024641
--- /dev/null
+++ b/ROMFS/px4fmu_common/init.d-posix/airframes/10990_sihsim_pa1
@@ -0,0 +1,64 @@
+#!/bin/sh
+#
+# @name PA-1 SIH proxy(X500 代理)
+#
+# @type Quadrotor
+#
+# ⚠️ 代理值:動力/慣量沿 SIH 預設(X500 級),PA-1 實機數值 rev A 實測定容
+#   (firmware/airframes/pa1/README.md);本 airframe 驗的是任務邏輯/參數/契約層。
+#
+
+. ${R}etc/init.d/rc.mc_defaults
+
+PX4_SIMULATOR=${PX4_SIMULATOR:=sihsim}
+PX4_SIM_MODEL=${PX4_SIM_MODEL:=quadx}
+
+param set-default SENS_EN_GPSSIM 1
+param set-default SENS_EN_BAROSIM 1
+param set-default SENS_EN_MAGSIM 1
+
+# disable some checks to allow to fly:
+# - without real battery
+param set-default CBRK_SUPPLY_CHK 894281
+# - without safety switch
+param set-default CBRK_IO_SAFETY 22027
+
+# Square quadrotor X PX4 numbering
+param set-default CA_ROTOR_COUNT 4
+param set-default CA_ROTOR0_PX 1
+param set-default CA_ROTOR0_PY 1
+param set-default CA_ROTOR1_PX -1
+param set-default CA_ROTOR1_PY -1
+param set-default CA_ROTOR2_PX 1
+param set-default CA_ROTOR2_PY -1
+param set-default CA_ROTOR2_KM -0.05
+param set-default CA_ROTOR3_PX -1
+param set-default CA_ROTOR3_PY 1
+param set-default CA_ROTOR3_KM -0.05
+
+param set-default PWM_MAIN_FUNC1 101
+param set-default PWM_MAIN_FUNC2 102
+param set-default PWM_MAIN_FUNC3 103
+param set-default PWM_MAIN_FUNC4 104
+
+param set SIH_VEHICLE_TYPE 0
+
+# ---- 失效保護參數包 v1(單一事實來源:build-and-first-flight.md §3;
+#      口徑同 tools/flight_ops/params/dev-machine-v1.params,F10 實測
+#      COM_LOW_BAT_ACT=3,勿回退 2=Land mode)----
+param set-default NAV_RCL_ACT 2
+param set-default COM_RC_LOSS_T 0.5
+param set-default NAV_DLL_ACT 0
+param set-default COM_LOW_BAT_ACT 3
+param set-default BAT_LOW_THR 0.20
+param set-default BAT_CRIT_THR 0.10
+param set-default BAT_EMERGEN_THR 0.05
+param set-default GF_ACTION 3
+param set-default GF_MAX_HOR_DIST 500
+param set-default GF_MAX_VER_DIST 100
+param set-default RTL_RETURN_ALT 40
+param set-default RTL_DESCEND_ALT 10
+param set-default COM_OBL_RC_ACT 0
+param set-default BAT1_N_CELLS 4
+param set-default BAT1_V_EMPTY 3.5
+param set-default BAT1_V_CHARGED 4.05
