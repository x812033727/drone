diff --git a/src/modules/mavlink/streams/BATTERY_DETAIL.hpp b/src/modules/mavlink/streams/BATTERY_DETAIL.hpp
new file mode 100644
index 0000000..a629f90
--- /dev/null
+++ b/src/modules/mavlink/streams/BATTERY_DETAIL.hpp
@@ -0,0 +1,62 @@
+#ifndef BATTERY_DETAIL_HPP
+#define BATTERY_DETAIL_HPP
+
+// drone_custom dialect(24152):智慧電池電芯級詳情;資料源 =
+// drone_battery_detail topic(firmware/ext;實機由 SMBus BMS 驅動發布,硬體階段)。
+
+#include <uORB/topics/drone_battery_detail.h>
+
+class MavlinkStreamBatteryDetail : public MavlinkStream
+{
+public:
+	static MavlinkStream *new_instance(Mavlink *mavlink) { return new MavlinkStreamBatteryDetail(mavlink); }
+
+	static constexpr const char *get_name_static() { return "BATTERY_DETAIL"; }
+	static constexpr uint16_t get_id_static() { return MAVLINK_MSG_ID_BATTERY_DETAIL; }
+
+	const char *get_name() const override { return get_name_static(); }
+	uint16_t get_id() override { return get_id_static(); }
+
+	unsigned get_size() override
+	{
+		return _sub.advertised() ? MAVLINK_MSG_ID_BATTERY_DETAIL_LEN + MAVLINK_NUM_NON_PAYLOAD_BYTES : 0;
+	}
+
+private:
+	explicit MavlinkStreamBatteryDetail(Mavlink *mavlink) : MavlinkStream(mavlink) {}
+
+	uORB::Subscription _sub{ORB_ID(drone_battery_detail)};
+
+	bool send() override
+	{
+		drone_battery_detail_s s;
+
+		if (_sub.update(&s)) {
+			mavlink_battery_detail_t msg{};
+
+			msg.time_boot_ms = s.timestamp / 1000;
+			msg.fault_flags = s.fault_flags;
+			msg.capacity_full_charge = s.capacity_full_charge_mah;
+			msg.capacity_remaining = s.capacity_remaining_mah;
+
+			for (unsigned i = 0; i < 14; ++i) {
+				msg.cell_voltages[i] = s.cell_voltages_mv[i];
+			}
+
+			msg.cycle_count = s.cycle_count;
+			msg.temperature = s.temperature_cdegc;
+			msg.current = s.current_ca;
+			msg.id = s.id;
+			msg.cell_count = s.cell_count;
+			msg.state_of_health = s.state_of_health;
+			msg.state_of_charge = s.state_of_charge;
+
+			mavlink_msg_battery_detail_send_struct(_mavlink->get_channel(), &msg);
+			return true;
+		}
+
+		return false;
+	}
+};
+
+#endif // BATTERY_DETAIL_HPP
diff --git a/src/modules/mavlink/streams/PAYLOAD_STATUS.hpp b/src/modules/mavlink/streams/PAYLOAD_STATUS.hpp
