+#ifndef SPRAY_TELEMETRY_HPP
+#define SPRAY_TELEMETRY_HPP
+
+// drone_custom dialect(24151):噴灑作業遙測(PB-1);資料源 =
+// drone_spray_status topic(firmware/ext;SITL 由 payload_sim/drone_spray 發布)。
+
+#include <uORB/topics/drone_spray_status.h>
+
+class MavlinkStreamSprayTelemetry : public MavlinkStream
+{
+public:
+	static MavlinkStream *new_instance(Mavlink *mavlink) { return new MavlinkStreamSprayTelemetry(mavlink); }
+
+	static constexpr const char *get_name_static() { return "SPRAY_TELEMETRY"; }
+	static constexpr uint16_t get_id_static() { return MAVLINK_MSG_ID_SPRAY_TELEMETRY; }
+
+	const char *get_name() const override { return get_name_static(); }
+	uint16_t get_id() override { return get_id_static(); }
+
+	unsigned get_size() override
+	{
+		return _sub.advertised() ? MAVLINK_MSG_ID_SPRAY_TELEMETRY_LEN + MAVLINK_NUM_NON_PAYLOAD_BYTES : 0;
+	}
+
+private:
+	explicit MavlinkStreamSprayTelemetry(Mavlink *mavlink) : MavlinkStream(mavlink) {}
+
+	uORB::Subscription _sub{ORB_ID(drone_spray_status)};
+
+	bool send() override
+	{
+		drone_spray_status_s s;
+
+		if (_sub.update(&s)) {
+			mavlink_spray_telemetry_t msg{};
+
+			msg.time_boot_ms = s.timestamp / 1000;
+			msg.flow_rate = s.flow_rate_ml_s;
+			msg.flow_rate_setpoint = s.flow_rate_setpoint_ml_s;
+			msg.volume_remaining = s.volume_remaining_ml;
+			msg.volume_consumed = s.volume_consumed_ml;
+			msg.application_rate = s.application_rate_ml_m2;
+			msg.pump_pressure = s.pump_pressure_bar;
+			msg.boom_width = s.boom_width_m;
+			msg.spray_flags = s.spray_flags;
+			msg.pump_state = s.pump_state;
+			msg.nozzles_active = s.nozzles_active;
+
+			mavlink_msg_spray_telemetry_send_struct(_mavlink->get_channel(), &msg);
+			return true;
+		}
+
+		return false;
+	}
+};
+
+#endif // SPRAY_TELEMETRY_HPP
