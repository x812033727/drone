@@ -0,0 +1,54 @@
+#ifndef PAYLOAD_STATUS_HPP
+#define PAYLOAD_STATUS_HPP
+
+// drone_custom dialect(24150):酬載通用狀態;資料源 = out-of-tree
+// drone_payload_status topic(firmware/ext,SITL 由 payload_sim 發布)。
+
+#include <uORB/topics/drone_payload_status.h>
+
+class MavlinkStreamDronePayloadStatus : public MavlinkStream
+{
+public:
+	static MavlinkStream *new_instance(Mavlink *mavlink) { return new MavlinkStreamDronePayloadStatus(mavlink); }
+
+	static constexpr const char *get_name_static() { return "PAYLOAD_STATUS"; }
+	static constexpr uint16_t get_id_static() { return MAVLINK_MSG_ID_PAYLOAD_STATUS; }
+
+	const char *get_name() const override { return get_name_static(); }
+	uint16_t get_id() override { return get_id_static(); }
+
+	unsigned get_size() override
+	{
+		return _sub.advertised() ? MAVLINK_MSG_ID_PAYLOAD_STATUS_LEN + MAVLINK_NUM_NON_PAYLOAD_BYTES : 0;
+	}
+
+private:
+	explicit MavlinkStreamDronePayloadStatus(Mavlink *mavlink) : MavlinkStream(mavlink) {}
+
+	uORB::Subscription _sub{ORB_ID(drone_payload_status)};
+
+	bool send() override
+	{
+		drone_payload_status_s s;
+
+		if (_sub.update(&s)) {
+			mavlink_payload_status_t msg{};
+
+			msg.time_boot_ms = s.timestamp / 1000;
+			msg.fault_flags = s.fault_flags;
+			msg.firmware_version = s.firmware_version;
+			msg.temperature = s.temperature_cdegc;
+			msg.payload_type = s.payload_type;
+			msg.payload_id = s.payload_id;
+			msg.state = s.state;
+			msg.vendor_status = s.vendor_status;
+
+			mavlink_msg_payload_status_send_struct(_mavlink->get_channel(), &msg);
+			return true;
+		}
+
+		return false;
+	}
+};
+
+#endif // PAYLOAD_STATUS_HPP
