# drone-agent 設定範本 → 複製到 /etc/drone/agent.env(chmod 600,含 TLS 私鑰路徑)。
# systemd EnvironmentFile 格式:KEY=value,不展開 shell、不加引號。

# --- 必填 ---
# 機隊內唯一機身識別碼(對齊雲端 fleet/{drone_id}/* 主題與裝置註冊)
DRONE_ID=dev-1
# MQTT broker(Phase 1 對外務必走 8883 mTLS,見下 TLS 段)
MQTT_HOST=broker.example.internal
MQTT_PORT=1883
# MAVSDK 連線字串:SITL=udpin://0.0.0.0:14540;實機序列埠=serial:///dev/ttyUSB0:57600
MAVLINK_URL=serial:///dev/ttyACM0:115200
# 遙測上報頻率 Hz
RATE=1.0

# --- 選配旗標(依空白切詞塞進 ExecStart 的 $EXTRA_ARGS)---
# 常見:連既有 mavsdk_server(若你另跑 standalone server)、log-svc 回收、關派遣。
# 範例:EXTRA_ARGS=--mavsdk-address localhost:50051 --log-svc-url http://logsvc.internal:8090
# Phase 0 開發內網可留空(drone_agent 自 spawn mavsdk_server、預設開啟雲端派遣)。
#
# OTA(G23,軟體套件空中更新,預設關):加 --enable-ota 訂閱 fleet/{drone_id}/cmd/ota。
# **務必同時設下方 OTA_PUBLIC_KEY**,否則 agent 雖訂閱但 fail-closed 拒絕所有安裝。
# 範例:EXTRA_ARGS=--enable-ota
EXTRA_ARGS=

# --- OTA 驗簽公鑰(僅 EXTRA_ARGS 含 --enable-ota 時需要)---
# drone_agent/ota.py 直接讀 env OTA_PUBLIC_KEY:指向 Ed25519 **公鑰** PEM 檔路徑。
# 未設 = 拒絕所有 OTA 安裝(fail-closed);私鑰只在雲端簽章側,絕不佈到機上。
#OTA_PUBLIC_KEY=/etc/drone/ota/ota_pubkey.pem

# --- MQTT mTLS(Phase 1 對外部署必填;drone_agent/tls.py 直接讀這三個 env)---
# 未設時走明文(僅限開發內網)。憑證由 PKI 簽發並佈建到機上(見 provisioning)。
#MQTT_TLS_CA=/etc/drone/certs/ca.crt
#MQTT_TLS_CERT=/etc/drone/certs/dev-1.crt
#MQTT_TLS_KEY=/etc/drone/certs/dev-1.key
